{
  "name": "showtrackr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted, mobile-first TV Time clone (SvelteKit + Postgres + Caddy, Docker-first).",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter ./apps/web dev",
    "build": "pnpm --filter ./apps/web build",
    "docker:up": "docker compose up -d --build"
  }
}

# =============================================================================
# ShowTrackr — environment configuration
# Copy this file to `.env` and fill in the blanks:  cp .env.example .env
# The single .env at the repo root is consumed by every compose service.
# NEVER commit the real .env (see .gitignore).
# =============================================================================

# --- Database ----------------------------------------------------------------
# Pick a strong password once and use the SAME value in both POSTGRES_PASSWORD and
# the DATABASE_URL below. Generate one with:  openssl rand -hex 24
# Compose fails fast if POSTGRES_PASSWORD is left unset (no baked-in default).
POSTGRES_USER=showtrackr
POSTGRES_PASSWORD=
POSTGRES_DB=showtrackr

# Connection string used by the app, the migrate job and the importer.
# Host `db` is the postgres compose service. Replace __SET_ME__ with the value
# of POSTGRES_PASSWORD above (URL-encode it if it contains special characters).
DATABASE_URL=postgres://showtrackr:__SET_ME__@db:5432/showtrackr

# --- TMDB metadata provider --------------------------------------------------
# Free v3 API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- App ---------------------------------------------------------------------
# Secret used to sign session cookies. Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Host port the app is published on (plain HTTP). Reach it at http://<host-ip>:${APP_PORT}
APP_PORT=8080

# Public base URL the app advertises for itself.
# Default (HTTP-first, no domain/proxy): http://localhost:8080
# A real https:// value is only needed for the optional TLS/Caddy path
# (docker compose --profile tls up -d), where Caddy derives its domain from it.
# ⚠ For --profile tls, set this to your real https:// domain BEFORE starting,
#   else Caddy binds the wrong address (and can't obtain a certificate).
PUBLIC_BASE_URL=http://localhost:8080

# --- Reverse proxy (Caddy) — ONLY for `--profile tls` ------------------------
# These have no effect on the default plain-HTTP setup. They only matter when you
# run the optional caddy service (docker compose --profile tls up -d) with a domain
# set in PUBLIC_BASE_URL above.
# Optional e-mail for Let's Encrypt expiry notices (see caddy/Caddyfile).
ACME_EMAIL=

# --- Importer (one-shot GDPR backfill) ---------------------------------------
# Path inside the importer container where ../gdpr-data is mounted (read-only).
GDPR_DATA_DIR=/gdpr-data

# --- Registry deploy (docker-compose.prod.yml ONLY) --------------------------
# Which published GHCR image tag docker-compose.prod.yml pulls for the app and
# migrate services. Defaults to `latest` when unset. Pin it to a specific build
# for reproducible deploys / rollbacks, e.g. a short-SHA tag from GHCR:
#   SHOWTRACKR_TAG=sha-1a2b3c4
# Has no effect on the dev docker-compose.yml (that one builds locally).
#SHOWTRACKR_TAG=latest

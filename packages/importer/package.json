{
  "name": "@mytvtime/importer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "GDPR export backfill CLI for MyTVTime (PLAN §8). Reconstructs the episode-by-episode watch history from TV Time's per-show watermark.",
  "license": "MIT",
  "bin": {
    "mytvtime-import": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types src/index.ts"
  },
  "dependencies": {
    "@mytvtime/db": "workspace:*",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}

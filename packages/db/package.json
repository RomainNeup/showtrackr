{
  "name": "@mytvtime/db",
  "version": "0.1.0",
  "type": "module",
  "description": "Drizzle schema, client factory and SQL migrations for MyTVTime (PostgreSQL 16).",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "drizzle",
    "drizzle.config.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate",
    "migrate": "node dist/migrate.js",
    "push": "drizzle-kit push",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3"
  }
}

# Use an npm-style flat node_modules layout.
#
# Rationale: the Docker runtime images run the built server (`node build/index.js`)
# and the importer CLI from a single copied `node_modules` tree. pnpm's default
# symlinked/isolated layout scatters each workspace package's deps into its own
# node_modules, which does not survive being copied across Docker build stages.
# The hoisted linker gives a single, self-contained node_modules that resolves
# correctly at runtime. It is npm-compatible and safe for all workspace packages.
node-linker=hoisted

# Keep the store on the default location; Docker builds mount a cache at /pnpm/store.
